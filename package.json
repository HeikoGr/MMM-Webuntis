{
  "name": "mmm-webuntis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeikoGr/MMM-Webuntis"
  },
  "version": "0.7.5",
  "description": "MagicMirror module to access Webuntis school timetables.",
  "main": "MMM-Webuntis.js",
  "exports": {
    ".": "./MMM-Webuntis.js",
    "./node_helper": "./node_helper.js",
    "./package.json": "./package.json"
  },
  "files": [
    "MMM-Webuntis.css",
    "node_helper.js",
    "lib/",
    "widgets/",
    "config/",
    "translations/"
  ],
  "sideEffects": true,
  "keywords": [
    "MagicMirror",
    "webuntis",
    "school",
    "timetable"
  ],
  "author": "HeikoGr",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "prepare": "node scripts/install-hooks.js",
    "lint": "eslint --ext .js && prettier --check .",
    "lint:fix": "eslint --fix && prettier --write .",
    "test:spelling": "cspell .",
    "test:auth:curl": "bash scripts/test_auth_with_curl.sh --from-config",
    "debug": "node cli/node_helper_wrapper.js",
    "check": "node scripts/magicmirror-check.mjs --current"
  },
  "lint-staged": {
    "*": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "otplib": "^13.3.0",
    "sanitize-html": "^2.17.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cspell": "^9.7.0",
    "eslint": "^10.0.3",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.4.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "npx --no-install lint-staged"
  }
}
