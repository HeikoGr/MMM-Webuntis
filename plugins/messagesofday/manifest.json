{
  "$schema": "../../docs/schemas/plugin-widget-manifest.schema.json",
  "id": "messagesofday",
  "version": "1.0.0",
  "title": "Messages of the Day",
  "type": "widget",
  "entry": {
    "frontend": "frontend.js",
    "backend": "backend.js",
    "styles": ["styles.css"]
  },
  "slots": ["main"],
  "order": 600,
  "capabilities": ["messages", "studentContext"],
  "configNamespace": "messagesofday",
  "activation": {
    "enabledByDefault": false,
    "displayAliases": ["messagesofday", "messages"]
  },
  "compatibility": {
    "contractVersion": 3,
    "hostApiVersion": 1
  }
}
