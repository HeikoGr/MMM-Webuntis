{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pm2: restart all",
      "type": "shell",
      "command": "pm2 restart all",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "close": true
      },
      "options": {
        "statusbar": {
          "label": "$(sync) Restart",
          "color": "#FF9800",
          "detail": "Restart all PM2 processes"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "lint + prettier",
      "type": "shell",
      "command": "node --run lint:fix",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "close": false
      },
      "isBackground": false,
      "options": {
        "statusbar": {
          "label": "$(check-all) Lint + Prettier",
          "color": "#00BCD4",
          "detail": "Run lint and prettier"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "pm2: logs (follow)",
      "type": "shell",
      "command": "pm2 logs --lines 200",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "isBackground": false,
      "options": {
        "statusbar": {
          "label": "$(eye) Logs",
          "color": "#4CAF50",
          "detail": "Follow PM2 logs"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm install",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "close": false
      },
      "isBackground": false,
      "options": {
        "statusbar": {
          "label": "$(eye) npm i",
          "color": "#ffe600",
          "detail": "npm install"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "bash: open terminal",
      "type": "shell",
      "command": "bash",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "isBackground": false,
      "options": {
        "statusbar": {
          "label": "$(terminal-bash) Bash",
          "color": "#607D8B",
          "detail": "Open an interactive Bash terminal"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "pm2: restart & clean",
      "type": "shell",
      "command": "clear && pm2 restart all && pm2 flush",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "close": true
      },
      "isBackground": false,
      "options": {
        "statusbar": {
          "hide": true,
          "label": "$(refresh) Restart & Clean",
          "color": "#9C27B0",
          "detail": "Restart all PM2 processes and flush logs"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "pm2: restart & logs (clean)",
      "dependsOrder": "sequence",
      "options": {
        "statusbar": {
          "label": "$(refresh) Restart & Logs (clean)",
          "color": "#9C27B0",
          "detail": "Restart all PM2 processes and flush logs"
        }
      },
      "dependsOn": ["pm2: restart & clean", "pm2: logs (follow)"],
      "problemMatcher": []
    }
  ]
}
